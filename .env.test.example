# Playwright E2E test-account credentials — EXAMPLE / PLACEHOLDERS ONLY.
#
# Copy this file to .env.test (which is gitignored) and fill in a REAL,
# dedicated test account created through the app's own signup flow.
# ⚠️ The repo is PUBLIC — never put real credentials in this example file
# or in any tracked file / commit message.
#
#   cp .env.test.example .env.test   # then edit .env.test with real values
#
TEST_USER_EMAIL=you@example.com
TEST_USER_PASSWORD=replace-with-test-account-password
